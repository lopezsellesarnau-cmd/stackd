---
import '../styles/tokens.css';
---

<section class="cta-final wrap" id="contacto" data-reveal>
  <span class="sec-eyebrow">// contacto</span>
  <h2 class="sec-title cta-title">¿Listo para automatizar tu negocio?</h2>
  <a href="mailto:info@louvrlabs.com" class="btn btn-primary">Escríbenos</a>
</section>

<style>
  .cta-final {
    padding-top: 60px;
    padding-bottom: 70px;
    text-align: center;
  }
  .cta-title {
    font-size: 30px;
    margin-bottom: 24px;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>
