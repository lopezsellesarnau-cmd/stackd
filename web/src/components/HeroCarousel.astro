---
import '../styles/tokens.css';
import { Image } from 'astro:assets';
import carrusel from '../assets/carrusel.png';
---

<div class="hero-carousel wrap">
  <Image
    src={carrusel}
    alt="Mockups de NOOK, SMASH, Volea, Getflow y Louvr Performance"
    widths={[600, 900, 1200, 1600]}
    sizes="100vw"
  />
</div>

<style>
  .hero-carousel {
    margin-top: 80px;
  }
  .hero-carousel :global(img) {
    width: 100%;
    height: auto;
  }

  @media (max-width: 900px) {
    .hero-carousel {
      margin-top: 70px;
    }
    .hero-carousel :global(img) {
      width: 100%;
    }
  }
</style>
